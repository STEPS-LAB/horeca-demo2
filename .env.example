# ─────────────────────────────────────────────
# LUMINA Hotel — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# PostgreSQL connection string.
# If not set, the app runs in demo mode using static data.
DATABASE_URL="postgresql://user:password@localhost:5432/lumina_hotel"

# ── Authentication ────────────────────────────
# Secret used to sign admin JWT sessions.
# Generate with: openssl rand -base64 64
JWT_SECRET="replace-with-a-strong-random-secret"

# ── Next.js ───────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://hotel-demo-eosin.vercel.app/"

# ── Optional: Vercel deployment ───────────────
# Only required for CI/CD deployment via GitHub Actions
# VERCEL_TOKEN="..."
# VERCEL_ORG_ID="..."
# VERCEL_PROJECT_ID="..."
